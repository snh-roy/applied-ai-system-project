# MoodSense AI Environment Variables
# Copy this file to .env and fill in your values

# Optional: OpenAI API Key (for enhanced features)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# Optional: Database Path (defaults to local SQLite)
DATABASE_URL=sqlite:///moodsense.db

# Optional: Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: ChromaDB Persist Directory
CHROMA_PERSIST_DIR=./chroma_db

# Crisis Hotline Numbers (customize for your region)
CRISIS_HOTLINE_PRIMARY=988
CRISIS_HOTLINE_TEXT=741741

# Feature Flags (true/false)
ENABLE_CRISIS_DETECTION=true
ENABLE_RAG_SYSTEM=true
ENABLE_AGENT_PLANNING=true
ENABLE_LOGGING=true

# Note: The system works without any of these configured.
# These are only needed for advanced features.